---
import type { CollectionEntry } from 'astro:content';

import FormattedDate from '@/components/FormattedDate.astro';

type Props = CollectionEntry<'posts'>['data'] & { id: string; isLink?: boolean };

const { isLink, title, pubDate, updatedDate, id, tags } = Astro.props;
---

<div class="header" style={`view-transition-name: post-${id};`}>
  <div class="time" data-pagefind-ignore>
    <FormattedDate date={pubDate} />
    {
      !isLink && updatedDate && (
        <span class="updated">
          Updated <FormattedDate date={updatedDate} />
        </span>
      )
    }
  </div>

  {
    isLink ? (
      <a href={`/posts/${id}/`}>
        <h2 class="h1 title">{title}</h2>
      </a>
    ) : (
      <h1 class="h1 title">{title}</h1>
    )
  }

  <ul class="tag-list" data-pagefind-ignore>
    {
      tags.sort().map((t) => (
        <li>
          <a href={`/tags/${t}/`}>#{t}</a>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .header {
    @media (min-width: 48rem) {
      display: grid;
      grid-template-columns: 8rem 1fr;
      column-gap: 4rem;
      row-gap: 1rem;
    }

    > *:first-child {
      grid-row: span 2 / span 2;
    }
  }

  .time {
    display: inline-block;
    margin-block-start: 0.5rem;
  }

  .updated {
    display: block;
    margin-block-start: 0.25rem;
    font-size: var(--font-size-sm);
    opacity: 0.7;
  }

  .title {
    margin-block: 0;
  }

  .tag-list {
    display: flex;
    gap: 1rem;
    list-style-type: none;
    margin: 0;
    padding: 0;
  }
</style>
